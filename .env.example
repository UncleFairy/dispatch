# Copy to .env.local to override defaults. The app runs without this file —
# these values only exist to make the mock auth explicit and configurable.

# Secret used to HMAC-sign the session cookie. Set a long random value in any
# real deployment; the app falls back to an insecure dev key if unset.
SESSION_SECRET=

# Shared password for all seeded accounts (there is no sign-up). Defaults to
# "dispatch" if unset. Seeded emails: ada@dispatch.dev, marco@dispatch.dev,
# priya@dispatch.dev, grace@dispatch.dev, alan@dispatch.dev
SEED_PASSWORD=dispatch
